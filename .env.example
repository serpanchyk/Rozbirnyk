# Shared environment for Docker Compose startup.
REDIS_HOST=redis
# Host ports exposed by Docker Compose.
BACKEND_PORT=8000
AGENT_SERVICE_PORT=8001
NEWS_SERVICE_PORT=8002
WIKI_SERVICE_PORT=8003
FRONTEND_PORT=8501

# URL baked into the frontend build.
VITE_BACKEND_URL=http://localhost:8000

# Required for news_service.
TAVILY_API_KEY=replace-me

# Optional AWS profile pass-through for Bedrock auth inside containers.
# AWS_PROFILE=default
# AWS_SHARED_CREDENTIALS_DIR=/home/you/.aws

# Optional direct AWS credential pass-through for Bedrock auth inside containers.
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
# AWS_SESSION_TOKEN=replace-me
# AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# Optional Bedrock target overrides for agent_service.
# MODEL__MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# MODEL__REGION_NAME=us-east-1

# Optional agent_service tracing overrides for Docker Compose runs.
OBSERVABILITY__LANGSMITH__ENABLED=false
# OBSERVABILITY__LANGSMITH__PROJECT=rozbirnyk
# OBSERVABILITY__LANGSMITH__API_KEY=lsv2_pt_replace_me
# OBSERVABILITY__LANGSMITH__ENDPOINT=https://api.smith.langchain.com

# Optional Bedrock pacing/retry overrides for agent_service.
MODEL__RUNTIME__MAX_CONCURRENCY=1
MODEL__RUNTIME__MIN_SECONDS_BETWEEN_CALLS=2.0
MODEL__RUNTIME__MAX_RETRIES=10
MODEL__RUNTIME__RETRY_BASE_SECONDS=1.0
MODEL__RUNTIME__RETRY_MAX_SECONDS=60.0
