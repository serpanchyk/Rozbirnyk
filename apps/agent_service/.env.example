# Optional local overrides for agent_service when not using Docker Compose.
SERVICE__PORT=8001
OBSERVABILITY__LANGSMITH__ENABLED=false
OBSERVABILITY__LANGSMITH__PROJECT=rozbirnyk
OBSERVABILITY__LANGSMITH__API_KEY=lsv2_pt_replace_me

MODEL__REGION_NAME=us-east-1
MODEL__MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

MCP_SERVERS__WIKI_SERVICE__HOST=localhost
MCP_SERVERS__WIKI_SERVICE__PORT=8003
MCP_SERVERS__WIKI_SERVICE__TRANSPORT=streamable_http
MCP_SERVERS__WIKI_SERVICE__ENDPOINT=mcp/
MCP_SERVERS__NEWS_SERVICE__HOST=localhost
MCP_SERVERS__NEWS_SERVICE__PORT=8002
MCP_SERVERS__NEWS_SERVICE__TRANSPORT=sse

WORLD_BUILDER__MAX_STEPS=8
WORLD_BUILDER__MAX_ACTORS=8
WORLD_BUILDER__MAX_STATE_FILES=12
